# Nextcloud SealedSecret placeholder
# Generate with:
#   kubectl create secret generic nextcloud-secrets \
#     --from-literal=postgres-password='<your-db-password>' \
#     --from-literal=admin-password='<your-admin-password>' \
#     --dry-run=client -o yaml | \
#   kubeseal --format yaml > nextcloud/templates/sealed-secret.yaml
#
# Required keys:
#   - postgres-password: PostgreSQL database password
#   - admin-password: Nextcloud admin user password

